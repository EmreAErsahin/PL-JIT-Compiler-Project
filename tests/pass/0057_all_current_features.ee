fn main() {
    // literals and declarations
    let x = 6;
    let y = 2;
    let flag = false;
    let value = nothing;

    // print with no argument prints nothing
    print();
    print((x + y) * (x - y));
    print(x > y);
    print(x == y);
    print(value == nothing);

    if ((x > y) && (flag || 1)) {
        print(1);
    } else {
        print(0);
    }

    {
        let x = 0;
        print(x);

        if (x) {
            print(9);
        } else if (nothing) {
            print(8);
        } else {
            print(7);
        }
    }

    y = x / 3;
    print(y);

    if (flag) {
        print(4);
    } else if (y != 2) {
        print(5);
    } else {
        print(6);
    }

    flag = true;
    print(flag && (y >= 2));
    print((0 || flag) && (nothing || true));
}
