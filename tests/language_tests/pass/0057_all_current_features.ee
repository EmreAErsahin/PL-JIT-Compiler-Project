fn main() {
    // literals and declarations
    let x = 6;
    let y = 2;
    let flag = false;
    let value = nothing;

    // print with no argument prints nothing
    print();
    println((x + y) * (x - y));
    println(x > y);
    println(x == y);
    println(value == nothing);

    if ((x > y) && (flag || 1)) {
        println(1);
    } else {
        println(0);
    }

    {
        let x = 0;
        println(x);

        if (x) {
            println(9);
        } else if (nothing) {
            println(8);
        } else {
            println(7);
        }
    }

    y = x / 3;
    println(y);

    if (flag) {
        println(4);
    } else if (y != 2) {
        println(5);
    } else {
        println(6);
    }

    flag = true;
    println(flag && (y >= 2));
    println((0 || flag) && (nothing || true));
}
